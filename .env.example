# AI provider — the app picks one based on which key is set:
#   GEMINI_API_KEY  -> Google Gemini (free tier, recommended for testing)
#   ANTHROPIC_API_KEY -> Claude (paid, best quality)
#   neither -> demo mode (templated recaps, no real AI)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash   # optional override
ANTHROPIC_API_KEY=

# Steam Web API key — get one at https://steamcommunity.com/dev/apikey
# Without this, /connect runs in demo mode with sample data.
STEAM_API_KEY=

# Supabase (not wired yet)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
