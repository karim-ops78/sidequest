# Steam Web API key — get one at https://steamcommunity.com/dev/apikey
# Without this, /connect runs in demo mode with sample data.
STEAM_API_KEY=

# Supabase (not wired yet)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider — recaps use Google Gemini (free tier).
# Get a key at https://aistudio.google.com/apikey
# Without this, "Log a session" returns a sample recap instead of a real one.
GEMINI_API_KEY=

# Alternative AI provider (not wired yet)
# ANTHROPIC_API_KEY=
